# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ensindexer
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/replace-me
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/replace-me
ENVIO_API_KEY=
HYPERSYNC_URL=https://eth.hypersync.xyz
RAW_ARCHIVE_DIR=.raw-archive

# Chain/runtime
CHAIN_ID=1
BIND_ADDRESS=127.0.0.1:8080

# Serve-time indexing controls
ENABLE_BACKFILL=false
ENABLE_LIVE_INDEXING=false
BACKFILL_SOURCE=rpc
LIVE_INDEXING_SOURCE=rpc
ARCHIVE_BACKFILLS=false
INDEXER_CONFIRMATION_DEPTH=12
BACKFILL_BATCH_BLOCKS=1000
LIVE_POLL_SECONDS=12

# Official subgraph comparison
SUBGRAPH_URL=https://gateway.thegraph.com/api/subgraphs/id/5XqPmWe6gjyrJtFn9cLy237i4cWw2j9HcUJEXsP5qGtH
SUBGRAPH_AUTH_TOKEN=

# Logging
RUST_LOG=cli=info,server=info,ingest=info,projection=info,storage=info,tower_http=info
