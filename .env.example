# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ensindexer
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/replace-me
ENVIO_API_KEY=
HYPERSYNC_URL=https://eth.hypersync.xyz
RAW_ARCHIVE_DIR=.raw-archive

# Chain/runtime
CHAIN_ID=1
BIND_ADDRESS=127.0.0.1:8080
GRAPHQL_SANDBOX=true
BACKFILL_SOURCE=auto
INDEXER_CONFIRMATION_DEPTH=12
BACKFILL_BATCH_BLOCKS=1000
LIVE_POLL_SECONDS=12

# Logging
RUST_LOG=cli=info,server=info,ingest=info,projection=info,storage=info,tower_http=info
